{
  "expo": {
    "name": "Медицинский ассистент",
    "slug": "medical-assistant-ios",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "medical-assistant-ios",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.pma.health.assistant",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSCameraUsageDescription": "Приложению нужен доступ к камере для съёмки медицинских документов и анализов.",
        "NSPhotoLibraryUsageDescription": "Приложению нужен доступ к фото для загрузки документов из галереи.",
        "NSPhotoLibraryAddUsageDescription": "Приложению нужен доступ для сохранения экспортированных документов."
      }
    },
    "android": {
      "package": "com.pma.health.assistant.android.stub",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Приложению нужен доступ к фото для загрузки медицинских документов.",
          "cameraPermission": "Приложению нужен доступ к камере для съёмки медицинских документов."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
