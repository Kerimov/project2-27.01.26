# Скопируйте в .env.local и заполните значения

# Локально (docker-compose up -d):
DATABASE_URL="postgresql://medical:medical123@localhost:5432/medical_dev"
# Для Vercel — URL из Storage → Postgres (начинается с postgresql://)
JWT_SECRET=change-me
PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com

# DeepSeek — облачный чат / парсер
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama — локально (переключение в /admin/settings)
OLLAMA_DISABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava
OLLAMA_TIMEOUT_MS=120000

# OCR (опционально)
OCR_SPACE_API_KEY=
