# JWT Secret для аутентификации (ОБЯЗАТЕЛЬНО - измените в продакшене!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# OCR.space API Key (опционально - есть fallback на Tesseract.js)
OCR_SPACE_API_KEY=your-ocr-space-api-key
# PDF > 1 MB: Tesseract (pdf-to-img + tesseract.js), см. lib/pdf-tesseract.ts
# TESSERACT_PDF_MAX_PAGES=20
# TESSERACT_PDF_SCALE=2

# Админские email адреса (через запятую)
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com,admin2@example.com

# База данных
# Для разработки (SQLite)
DATABASE_URL="file:./prisma/dev.db"
# Для продакшена (PostgreSQL) - получите URL от Vercel или другого провайдера
# DATABASE_URL="postgresql://username:password@host:port/database"

# Порт сервера (опционально)
PORT=3000

# Ollama (локальная LLM для AI функций)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava
# OLLAMA_DISABLED=true
# OLLAMA_API_KEY=  # только если Ollama за reverse-proxy с авторизацией

# NEXTAUTH_URL (для аутентификации в продакшене)
NEXTAUTH_URL=http://localhost:3000
